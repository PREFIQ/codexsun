{
  "name": "@codexsun/framework",
  "version": "1.0.23",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./index.js"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "default": "./api.js"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "default": "./config.js"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "default": "./db.js"
    },
    "./env": {
      "types": "./src/env/index.ts",
      "default": "./env.js"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "default": "./errors.js"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "default": "./events.js"
    },
    "./health": {
      "types": "./src/health/index.ts",
      "default": "./health.js"
    },
    "./http": {
      "types": "./src/http/index.ts",
      "default": "./http.js"
    },
    "./logger": {
      "types": "./src/logger/index.ts",
      "default": "./logger.js"
    },
    "./modules": {
      "types": "./src/modules/index.ts",
      "default": "./modules.js"
    },
    "./queue": {
      "types": "./src/queue/index.ts",
      "default": "./queue.js"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "default": "./storage.js"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "mariadb": "^3.5.3",
    "mysql2": "^3.11.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
