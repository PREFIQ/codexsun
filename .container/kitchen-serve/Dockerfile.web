FROM node:22-bookworm-slim AS build
ARG VITE_PLATFORM_API_URL=http://localhost:7010
ARG VITE_KITCHEN_SERVE_API_URL=http://localhost:7110
ENV VITE_PLATFORM_API_URL=$VITE_PLATFORM_API_URL
ENV VITE_KITCHEN_SERVE_API_URL=$VITE_KITCHEN_SERVE_API_URL
ENV KITCHEN_SERVE_WEB_PORT=7120
ENV NODE_ENV=production
WORKDIR /app
COPY . .
RUN npm ci \
  && npm run build -w @codexsun/framework \
  && npm run build -w @codexsun/kitchen-serve-web

FROM nginx:1.28-alpine AS runtime
ARG CODEXSUN_VERSION=1.0.32
LABEL org.opencontainers.image.title="CODEXSUN Kitchen Serve Web" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"
COPY .container/nginx-spa.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist/apps/kitchen-serve/web /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=15s --timeout=3s --start-period=10s --retries=5 \
  CMD wget -qO- http://127.0.0.1/health >/dev/null || exit 1
