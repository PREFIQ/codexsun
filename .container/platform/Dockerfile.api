FROM node:22-bookworm-slim AS build

WORKDIR /app
COPY . .
RUN npm ci \
  && npm run build -w @codexsun/framework \
  && npm run build -w @codexsun/platform-api

FROM build AS migrations
ARG CODEXSUN_VERSION=1.0.32
LABEL org.opencontainers.image.title="CODEXSUN Database Migrations" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"
ENV NODE_ENV=production
CMD ["npm", "run", "db:migrations:run"]

FROM build AS production-dependencies
RUN npm prune --omit=dev

FROM node:22-bookworm-slim AS runtime

ARG CODEXSUN_VERSION=1.0.32
LABEL org.opencontainers.image.title="CODEXSUN Platform API" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"

WORKDIR /app
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates mariadb-client \
  && rm -rf /var/lib/apt/lists/* \
  && mkdir -p /storage \
  && chown node:node /storage

COPY --from=production-dependencies /app/node_modules ./node_modules
COPY --from=build /app/packages/framework ./packages/framework
COPY --from=build /app/apps/platform/api/package.json ./apps/platform/api/package.json
COPY --from=build /app/dist ./dist

ENV NODE_ENV=production
USER node
EXPOSE 7010
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=10 \
  CMD node -e "fetch('http://127.0.0.1:7010/health').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"
CMD ["node", "dist/apps/platform/api/server.js"]
