FROM node:22-bookworm-slim AS build

WORKDIR /app
RUN npm install --global npm@11.17.0
COPY package.json package-lock.json .npmrc tsconfig.json tsconfig.base.json turbo.json ./
COPY tools ./tools
COPY packages/framework ./packages/framework
COPY apps/platform/api ./apps/platform/api
COPY apps/core/api ./apps/core/api
COPY apps/billing/api ./apps/billing/api

RUN npm ci \
  && npm run build -w @codexsun/framework \
  && npm run build -w @codexsun/platform-api \
  && npm run build -w @codexsun/core-api \
  && npm run build -w @codexsun/billing-api

FROM build AS migrations
ARG CODEXSUN_VERSION=1.0.33
LABEL org.opencontainers.image.title="CODEXSUN Billing Stack Migrations" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"
ENV NODE_ENV=production
CMD ["npm", "run", "db:migrations:run"]

FROM build AS production-dependencies
RUN npm prune --omit=dev

FROM node:22-bookworm-slim AS runtime

ARG CODEXSUN_VERSION=1.0.33
LABEL org.opencontainers.image.title="CODEXSUN Billing Stack API" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"

WORKDIR /app
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates mariadb-client \
  && rm -rf /var/lib/apt/lists/* \
  && mkdir -p /storage /app/apps/platform/web/public \
  && ln -s /storage/tenants /app/storage \
  && ln -s /storage/app/public /app/apps/platform/web/public/storage \
  && chown -R node:node /storage /app/apps/platform

COPY --from=production-dependencies /app/node_modules ./node_modules
COPY --from=build /app/packages/framework ./packages/framework
COPY --from=build /app/apps/platform/api/package.json ./apps/platform/api/package.json
COPY --from=build /app/apps/core/api/package.json ./apps/core/api/package.json
COPY --from=build /app/apps/billing/api/package.json ./apps/billing/api/package.json
COPY --from=build /app/dist ./dist
COPY .container/billing/api-entrypoint.sh /usr/local/bin/codexsun-api-entrypoint

RUN chmod +x /usr/local/bin/codexsun-api-entrypoint
ENV NODE_ENV=production
USER node
EXPOSE 7010 7030 7050
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=10 \
  CMD node -e "fetch('http://127.0.0.1:'+process.env.HEALTH_PORT+'/health').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"
ENTRYPOINT ["codexsun-api-entrypoint"]
