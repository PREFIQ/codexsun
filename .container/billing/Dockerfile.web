ARG NODE_RUNTIME_VERSION=26.5.0
FROM node:${NODE_RUNTIME_VERSION}-bookworm-slim AS build

ARG NPM_RUNTIME_VERSION=12.0.1
ARG PLATFORM_API_URL
ARG DEFAULT_TENANT_NAME=Codexsun
ARG DEV_AUTO_TENANT_LOGIN=0
ENV PLATFORM_API_URL=$PLATFORM_API_URL
ENV DEFAULT_TENANT_NAME=$DEFAULT_TENANT_NAME
ENV DEV_AUTO_TENANT_LOGIN=$DEV_AUTO_TENANT_LOGIN
ENV NODE_ENV=development

WORKDIR /app
RUN npm install --global npm@${NPM_RUNTIME_VERSION}
COPY package.json package-lock.json .npmrc tsconfig.json tsconfig.base.json turbo.json ./
COPY tools ./tools
COPY packages/framework ./packages/framework
COPY packages/ui ./packages/ui
COPY apps/platform/api ./apps/platform/api
COPY apps/platform/web ./apps/platform/web
COPY apps/core/api ./apps/core/api
COPY apps/core/web ./apps/core/web
COPY apps/billing/api ./apps/billing/api
COPY apps/billing/web ./apps/billing/web
COPY apps/mail/api ./apps/mail/api
COPY apps/mail/web ./apps/mail/web

RUN rm -rf apps/platform/web/public/storage \
  && mkdir -p apps/platform/web/public/storage \
  && npm ci \
  && npm run build -w @codexsun/framework \
  && npm run build -w @codexsun/core-web \
  && npm run build -w @codexsun/billing-web \
  && npm run build -w @codexsun/mail-web \
  && npm run build -w @codexsun/platform-web \
  && npm run dependencies:check

FROM nginx:1.28-alpine AS runtime

ARG CODEXSUN_VERSION=1.0.38
LABEL org.opencontainers.image.title="CODEXSUN Billing Stack Web" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"

COPY .container/scripts/nginx-spa.conf /etc/nginx/conf.d/default.conf
COPY .container/scripts/web-entrypoint.sh /usr/local/bin/codexsun-web-entrypoint
COPY --from=build /app/dist/apps/platform/web /opt/codexsun-web/platform

RUN chmod +x /usr/local/bin/codexsun-web-entrypoint
EXPOSE 80
HEALTHCHECK --interval=15s --timeout=3s --start-period=10s --retries=5 \
  CMD wget -qO- http://127.0.0.1/health >/dev/null || exit 1
ENTRYPOINT ["codexsun-web-entrypoint"]
