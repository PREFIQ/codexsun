NODE_ENV=production
NODE_RUNTIME_VERSION=26.5.0
NPM_RUNTIME_VERSION=12.0.1

# prepare-env.sh updates this from package.json on every deployment.
CODEXSUN_VERSION=1.0.40
CODEXSUN_IMAGE_REGISTRY=codexsun
CODEXSUN_DOCKER_NETWORK=codexsun-network
CODEXSUN_BIND_ADDRESS=127.0.0.1

MARIADB_BASE_IMAGE=mariadb:11.8
MARIADB_IMAGE_TAG=11.8-codexsun-1.0.40
MARIADB_ROOT_PASSWORD=change_this_mariadb_root_password
MARIADB_HOST_PORT=3307
MARIADB_DATA_VOLUME=codexsun-mariadb-data
MARIADB_BACKUP_VOLUME=codexsun-mariadb-backups

DB_DRIVER=mariadb
DB_HOST=codexsun-mariadb
DB_PORT=3306
# DB_USER, DB_PASSWORD, and DB_MASTER_NAME are imported from the repository .env
# when this deployment input is created. Container-to-container traffic stays on 3306.
DB_USER=root
DB_PASSWORD=change_this_database_password
DB_MASTER_NAME=cxsun_master_db

REDIS_BASE_IMAGE=redis:7.4-alpine
REDIS_IMAGE_TAG=7.4-codexsun-1.0.40
REDIS_PASSWORD=change_this_redis_password
REDIS_HOST_PORT=6379
REDIS_DATA_VOLUME=codexsun-redis-data
CODEXSUN_QUEUE_BACKEND=bullmq-redis
CODEXSUN_REDIS_URL=change_this_generated_redis_url
CODEXSUN_QUEUE_WORKER_ENABLED=1

MAIL_ENABLED=1
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_SECURE=0
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=CODEXSUN
MAIL_REPLY_TO=

FILEBROWSER_BASE_IMAGE=filebrowser/filebrowser:v2.63.5
MEDIA_IMAGE_TAG=1.0.40-filebrowser2.63.5
MEDIA_HOST_PORT=7090
MEDIA_ADMIN_USER=admin
# Defaults to SUPER_ADMIN_PASSWORD from repository .env; generated if unavailable.
MEDIA_ADMIN_PASSWORD=change_this_media_admin_password
MEDIA_DATA_VOLUME=codexsun-media-data
MEDIA_DB_VOLUME=codexsun-media-db

BILLING_STACK_API_IMAGE_TAG=1.0.40
BILLING_STACK_WEB_IMAGE_TAG=1.0.40
BILLING_STACK_MIGRATIONS_IMAGE_TAG=1.0.40
BILLING_STACK_DATA_VOLUME=codexsun-billing-stack-data


JWT_SECRET=change_this_jwt_secret
AUTH_MODE=jwt

PLATFORM_API_PORT=7010
PLATFORM_WEB_PORT=7020

PLATFORM_WEB_ORIGIN=http://localhost:7020
PLATFORM_API_URL=http://localhost:7010

SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SOFTWARE_ADMIN_NAME=
SOFTWARE_ADMIN_EMAIL=
SOFTWARE_ADMIN_PASSWORD=
TENANT_ADMIN_NAME=
TENANT_ADMIN_EMAIL=
TENANT_ADMIN_PASSWORD=

CODEXSUN_DB_FRESH_ON_START=0
CODEXSUN_DB_RESET_CONFIRM=
CODEXSUN_ALLOW_PRODUCTION_DB_RESET=0
# Required before production migrations. For a verified empty first deployment,
# use a recorded value such as initial-empty-database-YYYYMMDD.
CODEXSUN_VERIFIED_BACKUP_ID=
ENABLE_DEFAULT_TENANT_SEED=1
DEFAULT_TENANT_CORPORATE_ID=CODEXSUN
DEFAULT_TENANT_DB_NAME=codexsun_tenant_codexsun
DEFAULT_TENANT_DOMAIN=codexsun.localhost
DEFAULT_TENANT_NAME=Codexsun
DEFAULT_TENANT_SLUG=codexsun
DEFAULT_TENANT_ADMIN_NAME=
DEFAULT_TENANT_ADMIN_EMAIL=
DEFAULT_TENANT_ADMIN_PASSWORD=
TENANT_DOMAIN_BASE=localhost

GSP_ENVIRONMENT=sandbox
GSP_SANDBOX_BASE_URL=https://apisandbox.whitebooks.in
GSP_BASE_URL=https://api.whitebooks.in
GSP_EMAIL=
GSP_USERNAME=
GSP_PASSWORD=
GSP_CLIENT_ID=
GSP_CLIENT_SECRET=
GSP_GSTIN=
GSP_IP_ADDRESS=0.0.0.0
