NODE_ENV=production
CODEXSUN_IMAGE=codexsun:local

# Use "internal" or "external" with .container/setup.sh.
CODEXSUN_DB_MODE=internal
CODEXSUN_REDIS_MODE=internal

DB_DRIVER=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_USER=codexsun
DB_PASSWORD=change_this_database_password
DB_MASTER_NAME=codexsun_master
MARIADB_ROOT_PASSWORD=change_this_root_password

CODEXSUN_QUEUE_BACKEND=bullmq
CODEXSUN_REDIS_URL=redis://redis:6379

JWT_SECRET=change_this_with_openssl_rand_hex_32
AUTH_MODE=jwt

PLATFORM_API_PORT=7010
PLATFORM_WEB_PORT=7020
CORE_API_PORT=7030
CORE_WEB_PORT=7040
BILLING_API_PORT=7050
BILLING_WEB_PORT=7060
ACCOUNTS_API_PORT=7070
ACCOUNTS_WEB_PORT=7080

PLATFORM_API_HOST_PORT=7010
PLATFORM_WEB_HOST_PORT=7020
CORE_API_HOST_PORT=7030
CORE_WEB_HOST_PORT=7040
BILLING_API_HOST_PORT=7050
BILLING_WEB_HOST_PORT=7060
ACCOUNTS_API_HOST_PORT=7070
ACCOUNTS_WEB_HOST_PORT=7080
FILE_SERVER_HOST_PORT=7090
DOCKER_ADMIN_HOST_PORT=7091
MARIADB_ADMIN_HOST_PORT=7092
REDIS_ADMIN_HOST_PORT=7093

PLATFORM_WEB_ORIGIN=http://localhost:7020
CORE_WEB_ORIGIN=http://localhost:7040
BILLING_WEB_ORIGIN=http://localhost:7060
ACCOUNTS_WEB_ORIGIN=http://localhost:7080
VITE_PLATFORM_API_URL=http://localhost:7010
VITE_CORE_API_URL=http://localhost:7030
VITE_BILLING_API_URL=http://localhost:7050
VITE_ACCOUNTS_API_URL=http://localhost:7070
ACCOUNTS_API_URL=http://localhost:7070
VITE_TENANT_NAME=Codexsun

FILE_SERVER_USER=admin
FILE_SERVER_PASSWORD=change_this_file_admin_password
REDIS_ADMIN_HOSTS=local:redis:6379

CODEXSUN_DB_FRESH_ON_START=0
CODEXSUN_DB_RESET_CONFIRM=
CODEXSUN_ALLOW_PRODUCTION_DB_RESET=0
ENABLE_DEFAULT_TENANT_SEED=0
TENANT_DOMAIN_BASE=localhost
DEFAULT_TENANT_NAME=
DEFAULT_TENANT_CORPORATE_ID=
DEFAULT_TENANT_SLUG=
DEFAULT_TENANT_DB_NAME=
DEFAULT_TENANT_DOMAIN=localhost
DEFAULT_TENANT_ADMIN_NAME=
DEFAULT_TENANT_ADMIN_EMAIL=
DEFAULT_TENANT_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SOFTWARE_ADMIN_NAME=
SOFTWARE_ADMIN_EMAIL=
SOFTWARE_ADMIN_PASSWORD=
