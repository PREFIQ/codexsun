NODE_ENV=production

# All CODEXSUN-owned images use the workspace release version. Upstream base
# images are pinned to explicit version streams; never use latest in production.
CODEXSUN_VERSION=1.0.32
CODEXSUN_IMAGE_REGISTRY=codexsun
CODEXSUN_DOCKER_NETWORK=codexsun-network
CODEXSUN_BIND_ADDRESS=127.0.0.1
MARIADB_BASE_IMAGE=mariadb:11.8
MARIADB_IMAGE_TAG=11.8-codexsun-1.0.32
REDIS_BASE_IMAGE=redis:7.4-alpine
REDIS_IMAGE_TAG=7.4-codexsun-1.0.32
FILEBROWSER_BASE_IMAGE=filebrowser/filebrowser:v2.63.5
PICTURES_IMAGE_TAG=1.0.32-filebrowser2.63.5
FILES_IMAGE_TAG=1.0.32-filebrowser2.63.5

DB_DRIVER=mariadb
DB_HOST=codexsun-mariadb
DB_PORT=3306
DB_USER=codexsun
DB_PASSWORD=change_this_database_password
DB_MASTER_NAME=codexsun_master
MARIADB_ROOT_PASSWORD=change_this_root_password
MARIADB_HOST_PORT=3306

REDIS_PASSWORD=
REDIS_HOST_PORT=6379
CODEXSUN_QUEUE_BACKEND=bullmq-redis
CODEXSUN_REDIS_URL=redis://codexsun-redis:6379
CODEXSUN_QUEUE_WORKER_ENABLED=1

JWT_SECRET=change_this_with_openssl_rand_hex_32
AUTH_MODE=jwt

PLATFORM_API_HOST_PORT=7010
PLATFORM_WEB_HOST_PORT=7020
CORE_API_HOST_PORT=7030
CORE_WEB_HOST_PORT=7040
BILLING_API_HOST_PORT=7050
BILLING_WEB_HOST_PORT=7060
FILES_HOST_PORT=7090
PICTURES_HOST_PORT=7094
KITCHEN_SERVE_API_HOST_PORT=7110
KITCHEN_SERVE_WEB_HOST_PORT=7120

PLATFORM_WEB_ORIGIN=http://localhost:7020
CORE_WEB_ORIGIN=http://localhost:7040
BILLING_WEB_ORIGIN=http://localhost:7060
KITCHEN_SERVE_WEB_ORIGIN=http://localhost:7120
PLATFORM_API_URL=http://codexsun-platform-api:7010
CORE_API_URL=http://codexsun-core-api:7030
VITE_PLATFORM_API_URL=http://localhost:7010
VITE_CORE_API_URL=http://localhost:7030
VITE_BILLING_API_URL=http://localhost:7050
VITE_KITCHEN_SERVE_API_URL=http://localhost:7110
VITE_TENANT_NAME=Codexsun

PICTURES_ADMIN_USER=admin
# setup-media.sh replaces both password values with SUPER_ADMIN_PASSWORD from the repository .env.
PICTURES_ADMIN_PASSWORD=change_this_pictures_admin_password
FILES_ADMIN_USER=admin
FILES_ADMIN_PASSWORD=change_this_files_admin_password

# Explicit stable volume names keep data independent from Compose project names.
MARIADB_DATA_VOLUME=codexsun-mariadb-data
MARIADB_BACKUP_VOLUME=codexsun-mariadb-backups
REDIS_DATA_VOLUME=codexsun-redis-data
PLATFORM_DATA_VOLUME=codexsun-platform-data
CORE_DATA_VOLUME=codexsun-core-data
BILLING_DATA_VOLUME=codexsun-billing-data
KITCHEN_SERVE_DATA_VOLUME=codexsun-kitchen-serve-data
PICTURES_DATA_VOLUME=codexsun-pictures-data
PICTURES_DB_VOLUME=codexsun-pictures-db
FILES_DATA_VOLUME=codexsun-files-data
FILES_DB_VOLUME=codexsun-files-db

CODEXSUN_DB_FRESH_ON_START=0
CODEXSUN_DB_RESET_CONFIRM=
CODEXSUN_ALLOW_PRODUCTION_DB_RESET=0
ENABLE_DEFAULT_TENANT_SEED=0
TENANT_DOMAIN_BASE=localhost

# Optional GST provider credentials for Billing.
GSP_ENVIRONMENT=sandbox
GSP_EMAIL=
GSP_USERNAME=
GSP_PASSWORD=
GSP_CLIENT_ID=
GSP_CLIENT_SECRET=
GSP_GSTIN=
GSP_IP_ADDRESS=0.0.0.0
