FROM node:22-bookworm-slim AS build

ENV NODE_ENV=development
WORKDIR /app
RUN npm install --global npm@11.17.0
COPY package.json package-lock.json .npmrc tsconfig.json tsconfig.base.json turbo.json ./
COPY tools ./tools
COPY packages/ui ./packages/ui
COPY apps/sites/web ./apps/sites/web

RUN npm ci \
  && npm run build -w @codexsun/sites-web \
  && npm run dependencies:check

FROM nginx:1.28-alpine AS runtime

ARG CODEXSUN_VERSION=1.0.37
LABEL org.opencontainers.image.title="CODEXSUN Public Sites" \
      org.opencontainers.image.version="$CODEXSUN_VERSION"

COPY .container/scripts/nginx-spa.conf /etc/nginx/conf.d/default.conf
COPY .container/scripts/site-entrypoint.sh /usr/local/bin/codexsun-site-entrypoint
COPY --from=build /app/dist/apps/sites/web/codexsun /opt/codexsun-sites/codexsun
COPY --from=build /app/dist/apps/sites/web/logicx /opt/codexsun-sites/logicx
COPY --from=build /app/dist/apps/sites/web/techmedia /opt/codexsun-sites/techmedia

RUN chmod +x /usr/local/bin/codexsun-site-entrypoint
EXPOSE 80
HEALTHCHECK --interval=15s --timeout=3s --start-period=10s --retries=5 \
  CMD wget -qO- http://127.0.0.1/health >/dev/null || exit 1
ENTRYPOINT ["codexsun-site-entrypoint"]
