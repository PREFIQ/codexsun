{
  "name": "@codexsun/sites-web",
  "version": "1.0.36",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./runtime/index.ts",
    "./codexsun": "./clients/codexsun/index.ts",
    "./logicx": "./clients/logicx/index.ts",
    "./techmedia": "./clients/techmedia/index.ts"
  },
  "scripts": {
    "dev": "node ../../../tools/preflight.mjs sites-web codexsun",
    "dev:codexsun": "node ../../../tools/preflight.mjs sites-web codexsun 7130",
    "dev:logicx": "node ../../../tools/preflight.mjs sites-web logicx 7131",
    "dev:techmedia": "node ../../../tools/preflight.mjs sites-web techmedia 7132",
    "build": "tsc -p tsconfig.json && vite build --mode codexsun && vite build --mode logicx && vite build --mode techmedia",
    "build:codexsun": "tsc -p tsconfig.json && vite build --mode codexsun",
    "build:logicx": "tsc -p tsconfig.json && vite build --mode logicx",
    "build:techmedia": "tsc -p tsconfig.json && vite build --mode techmedia",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint clients runtime shared src --ext .ts,.tsx"
  },
  "dependencies": {
    "@codexsun/ui": "^1.0.36",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/bebas-neue": "^5.2.7",
    "@vitejs/plugin-react": "^6.0.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "typescript": "^5.7.2"
  }
}
