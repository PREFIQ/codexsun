{
  "name": "@codexsun/platform-api",
  "version": "1.0.19",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../../tools/preflight.mjs platform-api",
    "dev:fast": "npm run dev",
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx src/database/db-cli.ts migrate",
    "db:migrations:list": "tsx src/database/db-cli.ts migrations:list",
    "db:migrations:preflight": "tsx src/database/db-cli.ts migrations:preflight",
    "db:migrations:run": "tsx src/database/db-cli.ts migrations:run",
    "db:migrations:test-local": "tsx src/database/db-cli.ts migrations:test-local",
    "db:seed": "tsx src/database/db-cli.ts seed",
    "db:drop": "tsx src/database/db-cli.ts drop",
    "dbmigrate:fresh": "tsx src/database/db-cli.ts fresh",
    "db:dump:create": "tsx src/database/db-cli.ts dump:create",
    "db:dump:download": "tsx src/database/db-cli.ts dump:download",
    "db:restore:test": "tsx src/database/db-cli.ts restore:test",
    "db:backup:verify": "tsx src/database/db-cli.ts backup:verify",
    "typecheck": "npm run build -w @codexsun/framework && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:e2e:tenant": "vitest run src/modules/tenant/tenant.database.e2e.test.ts src/auth/default-tenant-auth.e2e.test.ts"
  },
  "dependencies": {
    "@codexsun/framework": "^1.0.19",
    "bullmq": "^5.79.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.11.1",
    "kysely": "^0.29.0",
    "mysql2": "^3.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
