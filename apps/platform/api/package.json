{
  "name": "@codexsun/platform-api",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../../tools/preflight.mjs platform-api",
    "dev:fast": "npm run dev",
    "build": "tsc -p tsconfig.json",
