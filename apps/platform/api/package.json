    "fastify": "^5.2.1",
    "kysely": "^0.29.0",
    "mysql2": "^3.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
