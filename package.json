{
  "name": "codexsun",
  "version": "1.0.41",
  "private": true,
  "packageManager": "npm@12.0.1",
  "description": "CODEXSUN",
  "type": "module",
  "workspaces": [
    "apps/*/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "node tools/dev-stack.mjs",
    "dev:api": "node tools/preflight.mjs platform-api",
    "dev:web": "node tools/preflight.mjs platform-web",
    "test:product-stacks": "node --test tools/product-stack-contract.test.mjs",
    "stack:impact": "node tools/stack-impact.mjs",
    "stack:plan": "node tools/stack-release-plan.mjs",
    "preinstall": "node tools/enforce-root-install.mjs",
    "postinstall": "node tools/check-root-node-modules.mjs",
    "dependencies:clean": "node tools/clean-workspace-artifacts.mjs",
    "dependencies:check": "node tools/check-root-node-modules.mjs",
    "build": "node tools/clean-root-dist.mjs && node tools/clean-workspace-artifacts.mjs && node tools/run-turbo-clean.mjs build && node tools/collect-dist.mjs && node tools/clean-workspace-artifacts.mjs",
    "typecheck": "node tools/run-turbo-clean.mjs typecheck",
    "lint": "node tools/run-turbo-clean.mjs lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify:platform": "npm run check:module-boundaries && npm run typecheck && npm run build",
    "check": "npm run check:module-boundaries && npm run typecheck && npm run lint",
    "check:module-boundaries": "node tools/check-module-boundaries.mjs",
    "check:core-boundaries": "node tools/check-module-boundaries.mjs core",
    "db:migrate": "tsx apps/platform/api/src/database/db-cli.ts migrate",
    "db:migrations:list": "tsx apps/platform/api/src/database/db-cli.ts migrations:list",
    "db:migrations:preflight": "tsx apps/platform/api/src/database/db-cli.ts migrations:preflight",
    "db:migrations:run": "tsx apps/platform/api/src/database/db-cli.ts migrations:run",
    "db:migrations:test-local": "tsx apps/platform/api/src/database/db-cli.ts migrations:test-local",
    "db:seed": "tsx apps/platform/api/src/database/db-cli.ts seed",
    "db:drop": "tsx apps/platform/api/src/database/db-cli.ts drop",
    "dbmigrate:fresh": "tsx apps/platform/api/src/database/db-cli.ts fresh",
    "db:dump:create": "tsx apps/platform/api/src/database/db-cli.ts dump:create",
    "db:dump:download": "tsx apps/platform/api/src/database/db-cli.ts dump:download",
    "db:restore:test": "tsx apps/platform/api/src/database/db-cli.ts restore:test",
    "db:backup:verify": "tsx apps/platform/api/src/database/db-cli.ts backup:verify",
    "test:e2e:organisation": "tsx apps/core/api/src/modules/organisation/organisation.e2e.ts",
    "test:e2e:bootstrap": "tsx tools/e2e/platform-core-billing-bootstrap.e2e.ts",
    "test:e2e:composed-runtime": "tsx tools/e2e/composed-platform-runtime.e2e.ts",
    "test:e2e:persistence": "tsx tools/e2e/organisation-billing-persistence.e2e.ts",
    "test:e2e:live-mass": "tsx tools/e2e/live-five-tenant-mass.e2e.ts",
    "test:e2e:tenant-access": "tsx tools/e2e/tenant-access.e2e.ts",
    "version:show": "node tools/version/version.mjs show",
    "version:bump": "node tools/version-bump.mjs",
    "changelog:append": "node tools/version/version.mjs append",
    "check:versions": "node tools/check-versions.mjs",
    "github:now": "node tools/github-helper.mjs",
    "github:ssh-key": "node tools/github-ssh-key.mjs",
    "env:jwt-secret": "node tools/env-jwt-secret.mjs"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2",
    "typescript-eslint-compiler": "npm:typescript@6.0.3",
    "vite": "^8.1.5"
  },
  "engines": {
    "node": ">=26.5.0",
    "npm": ">=12.0.1"
  },
  "allowScripts": {
    "esbuild": true
  }
}
