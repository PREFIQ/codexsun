{
  "name": "codexsun",
  "version": "1.0.32",
  "private": true,
  "packageManager": "npm@11.17.0",
  "description": "CODEXSUN",
  "type": "module",
  "workspaces": [
    "apps/*/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev:api": "node tools/dev-stack.mjs api",
    "dev:web": "node tools/dev-stack.mjs web",
    "dev:data-bridge": "node tools/dev-stack.mjs data-bridge",
    "preinstall": "node tools/enforce-root-install.mjs",
    "postinstall": "node tools/check-root-node-modules.mjs",
    "dependencies:clean": "node tools/clean-workspace-artifacts.mjs",
    "dependencies:check": "node tools/check-root-node-modules.mjs",
    "build": "node tools/clean-root-dist.mjs && node tools/clean-workspace-artifacts.mjs && node tools/run-turbo-clean.mjs build && node tools/collect-dist.mjs && node tools/clean-workspace-artifacts.mjs",
    "typecheck": "node tools/run-turbo-clean.mjs typecheck",
    "lint": "node tools/run-turbo-clean.mjs lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify:platform": "npm run check:module-boundaries && npm run typecheck && npm run build",
    "verify:billing": "npm run check:module-boundaries && npm run typecheck && npm run build",
    "verify:core": "npm run check:module-boundaries && npm run typecheck && npm run build",
    "verify:data-bridge": "npm run check:module-boundaries && npm run typecheck && npm run build",
    "verify:kitchen-serve": "npm run check:module-boundaries && npm run typecheck && npm run build",
    "check": "npm run check:module-boundaries && npm run typecheck && npm run lint",
    "check:module-boundaries": "node tools/check-module-boundaries.mjs",
    "check:core-boundaries": "node tools/check-module-boundaries.mjs core",
    "db:migrate": "tsx tools/database-stack.ts migrate",
    "db:migrations:list": "npm run db:migrations:list -w @codexsun/platform-api",
    "db:migrations:preflight": "npm run db:migrations:preflight -w @codexsun/platform-api",
    "db:migrations:run": "tsx tools/database-stack.ts migrations:run",
    "db:migrations:test-local": "tsx tools/database-stack.ts migrations:test-local",
    "db:seed": "tsx tools/database-stack.ts seed",
    "db:drop": "npm run db:drop -w @codexsun/platform-api",
    "dbmigrate:fresh": "tsx tools/database-stack.ts fresh",
    "db:dump:create": "npm run db:dump:create -w @codexsun/platform-api",
    "db:dump:download": "npm run db:dump:download -w @codexsun/platform-api",
    "db:restore:test": "npm run db:restore:test -w @codexsun/platform-api",
    "db:backup:verify": "npm run db:backup:verify -w @codexsun/platform-api",
    "test:e2e:organisation": "tsx apps/core/api/src/modules/organisation/organisation.e2e.ts",
    "test:e2e:bootstrap": "tsx tools/e2e/platform-core-billing-bootstrap.e2e.ts",
    "test:e2e:persistence": "tsx tools/e2e/organisation-billing-persistence.e2e.ts",
    "test:e2e:live-mass": "tsx tools/e2e/live-five-tenant-mass.e2e.ts",
    "test:e2e:tenant-access": "tsx tools/e2e/tenant-access.e2e.ts",
    "version:show": "node tools/version/version.mjs show",
    "version:bump": "node tools/version-bump.mjs",
    "changelog:append": "node tools/version/version.mjs append",
    "check:versions": "node tools/check-versions.mjs",
    "github:now": "node tools/github-helper.mjs",
    "github:ssh-key": "node tools/github-ssh-key.mjs",
    "env:jwt-secret": "node tools/env-jwt-secret.mjs"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "recharts": "^2.15.4",
    "tailwindcss": "^4.3.1",
    "turbo": "^2.10.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "allowScripts": {
    "esbuild": true
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8"
  }
}
