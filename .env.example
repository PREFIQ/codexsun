# ── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
PLATFORM_API_HOST=127.0.0.1
PLATFORM_API_PORT=7010
PLATFORM_WEB_PORT=7020
PLATFORM_WEB_ORIGIN=http://127.0.0.1:7020
CORE_API_HOST=127.0.0.1
CORE_API_PORT=7030
CORE_WEB_PORT=7040
CORE_WEB_ORIGIN=http://127.0.0.1:7040
BILLING_API_HOST=127.0.0.1
BILLING_API_PORT=7050
BILLING_WEB_PORT=7060
BILLING_WEB_ORIGIN=http://127.0.0.1:7060
ACCOUNTS_API_HOST=127.0.0.1
ACCOUNTS_API_PORT=7070
ACCOUNTS_WEB_PORT=7080
ACCOUNTS_WEB_ORIGIN=http://127.0.0.1:7080
DATA_BRIDGE_API_HOST=127.0.0.1
DATA_BRIDGE_API_PORT=7090
DATA_BRIDGE_WEB_PORT=7100
DATA_BRIDGE_WEB_ORIGIN=http://127.0.0.1:7100
KITCHEN_SERVE_API_HOST=127.0.0.1
KITCHEN_SERVE_API_PORT=7110
KITCHEN_SERVE_WEB_PORT=7120
KITCHEN_SERVE_WEB_ORIGIN=http://127.0.0.1:7120

VITE_PLATFORM_API_URL=http://127.0.0.1:7010
PLATFORM_API_URL=http://127.0.0.1:7010
VITE_CORE_API_URL=http://127.0.0.1:7030
CORE_API_URL=http://127.0.0.1:7030
VITE_BILLING_API_URL=http://127.0.0.1:7050
VITE_ACCOUNTS_API_URL=http://127.0.0.1:7070
VITE_DATA_BRIDGE_API_URL=http://127.0.0.1:7090
VITE_KITCHEN_SERVE_API_URL=http://127.0.0.1:7110
ACCOUNTS_API_URL=http://127.0.0.1:7070
VITE_TENANT_NAME=Codexsun
# Local CODEXSUN tenant auto-login. Both flags must be enabled and NODE_ENV must be development.
VITE_DEV_AUTO_TENANT_LOGIN=0

# ── Database ─────────────────────────────────────────────────────────
DB_DRIVER=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_MASTER_NAME=

# Database lifecycle.
# CODEXSUN_DB_FRESH_ON_START=1 drops and rebuilds configured databases on API startup.
# Destructive actions require CODEXSUN_DB_RESET_CONFIRM=DROP_DATABASES.
# Production additionally requires CODEXSUN_ALLOW_PRODUCTION_DB_RESET=1.
CODEXSUN_DB_FRESH_ON_START=0
CODEXSUN_DB_RESET_CONFIRM=
CODEXSUN_ALLOW_PRODUCTION_DB_RESET=0

# Database maintenance and queue-backed backup/restore.
CODEXSUN_BACKUP_DIR=storage/backups/database
CODEXSUN_RESTORE_TEST_DB_NAME=
CODEXSUN_VERIFIED_BACKUP_ID=
CODEXSUN_ALLOW_LIVE_RESTORE=0
CODEXSUN_LIVE_RESTORE_CONFIRM=

# Queue backend. Use database locally; BullMQ/Redis is reserved for cloud scale.
CODEXSUN_QUEUE_BACKEND=database
CODEXSUN_REDIS_URL=redis://127.0.0.1:6379
CODEXSUN_QUEUE_WORKER_ENABLED=1
CODEXSUN_QUEUE_WORKER_INTERVAL_MS=5000
CODEXSUN_QUEUE_COMPLETED_RETENTION_DAYS=14
CODEXSUN_QUEUE_FAILED_RETENTION_DAYS=30

# Test-only default first tenant seed. Keep disabled for normal/live runtime.
# Set ENABLE_DEFAULT_TENANT_SEED=1 only for local smoke tests or e2e runs.
ENABLE_DEFAULT_TENANT_SEED=0
DEV_AUTO_TENANT_LOGIN=0
TENANT_DOMAIN_BASE=localhost
DEFAULT_TENANT_NAME=
DEFAULT_TENANT_CORPORATE_ID=
DEFAULT_TENANT_SLUG=
DEFAULT_TENANT_DB_NAME=
DEFAULT_TENANT_DOMAIN=localhost
DEFAULT_TENANT_ADMIN_NAME=
DEFAULT_TENANT_ADMIN_EMAIL=
DEFAULT_TENANT_ADMIN_PASSWORD=

# ── Auth ─────────────────────────────────────────────────────────────
# REQUIRED. No fallback.
JWT_SECRET=

# WhiteBooks GST provider. Keep all credentials server-side; never expose them as VITE_* values.
GSP_ENVIRONMENT=sandbox
GSP_SANDBOX_BASE_URL=https://apisandbox.whitebooks.in
GSP_BASE_URL=https://api.whitebooks.in
GSP_EMAIL=
GSP_USERNAME=
GSP_PASSWORD=
GSP_CLIENT_ID=
GSP_CLIENT_SECRET=
GSP_GSTIN=
GSP_IP_ADDRESS=0.0.0.0

# Auth mode: "jwt" (default, bearer token), "cookie" (web sessions), or "hybrid" (both).
AUTH_MODE=jwt

# ── Seed users (blank on live deployments) ───────────────────────────
# Optional first platform users. Leave blank on live and create users
# manually unless this deployment intentionally needs a seeded account.
SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

SOFTWARE_ADMIN_NAME=
SOFTWARE_ADMIN_EMAIL=
SOFTWARE_ADMIN_PASSWORD=

# Optional tenant setup helper account. Leave blank on live unless you
# intentionally want every newly setup tenant to receive this admin user.
TENANT_ADMIN_NAME=
TENANT_ADMIN_EMAIL=
TENANT_ADMIN_PASSWORD=

# ── Dev / Tooling ────────────────────────────────────────────────────
# Set to "abort" to prevent the dev preflight from killing active listeners.
# CODEXSUN_DEV_PORT_POLICY=abort

# Set to 1 for faster local restarts when the database is already prepared.
# Skips the API database preflight and startup database bootstrap.
CODEXSUN_DEV_SKIP_DB=0

# Database safety command guards.
# Required for npm run db:migrations:test-local after restoring a dump locally.
CODEXSUN_RESTORED_DUMP_TEST=0

# Required for npm run db:backup:verify.
CODEXSUN_BACKUP_VERIFY_ID=
